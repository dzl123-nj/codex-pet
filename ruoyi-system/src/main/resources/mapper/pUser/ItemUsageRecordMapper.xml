<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.player.mapper.ItemUsageRecordMapper">
    
    <resultMap type="ItemUsageRecord" id="ItemUsageRecordResult">
        <result property="id"    column="id"    />
        <result property="userId"    column="user_id"    />
        <result property="petId"    column="pet_id"    />
        <result property="itemId"    column="item_id"    />
        <result property="usageQuantity"    column="usage_quantity"    />
        <result property="usageTime"    column="usage_time"    />
        <result property="createTime"    column="create_time"    />
    </resultMap>

    <sql id="selectItemUsageRecordVo">
        select id, user_id, pet_id, item_id, usage_quantity, usage_time, create_time from item_usage_record
    </sql>

    <select id="selectItemUsageRecordList" parameterType="ItemUsageRecord" resultMap="ItemUsageRecordResult">
        <include refid="selectItemUsageRecordVo"/>
        <where>  
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="itemId != null "> and item_id = #{itemId}</if>
        </where>
    </select>
    
    <select id="selectItemUsageRecordById" parameterType="Long" resultMap="ItemUsageRecordResult">
        <include refid="selectItemUsageRecordVo"/>
        where id = #{id}
    </select>

    <insert id="insertItemUsageRecord" parameterType="ItemUsageRecord" useGeneratedKeys="true" keyProperty="id">
        insert into item_usage_record
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="petId != null">pet_id,</if>
            <if test="itemId != null">item_id,</if>
            <if test="usageQuantity != null">usage_quantity,</if>
            <if test="usageTime != null">usage_time,</if>
            <if test="createTime != null">create_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="petId != null">#{petId},</if>
            <if test="itemId != null">#{itemId},</if>
            <if test="usageQuantity != null">#{usageQuantity},</if>
            <if test="usageTime != null">#{usageTime},</if>
            <if test="createTime != null">#{createTime},</if>
         </trim>
    </insert>

    <update id="updateItemUsageRecord" parameterType="ItemUsageRecord">
        update item_usage_record
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null">user_id = #{userId},</if>
            <if test="petId != null">pet_id = #{petId},</if>
            <if test="itemId != null">item_id = #{itemId},</if>
            <if test="usageQuantity != null">usage_quantity = #{usageQuantity},</if>
            <if test="usageTime != null">usage_time = #{usageTime},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteItemUsageRecordById" parameterType="Long">
        delete from item_usage_record where id = #{id}
    </delete>

    <delete id="deleteItemUsageRecordByIds" parameterType="String">
        delete from item_usage_record where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>